{
  "import": [
    "nix/pkgs/portfolio-spell/node_modules/@cspell/dict-fr-fr/cspell-ext.json",
    "nix/pkgs/portfolio-spell/node_modules/@cspell/dict-es-es/cspell-ext.json"
  ],
  "dictionaries": ["project-words", "en", "fr-fr", "es-es"],
  "dictionaryDefinitions": [
    {
      "addWords": true,
      "name": "project-words",
      "path": "project-words.txt"
    }
  ],
  "ignorePaths": ["node_modules", "dist"],
  "language": "en,fr,es",
  "version": "0.2"
}

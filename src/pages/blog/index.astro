---
import Base from "layouts/Base.astro";
import PostPreview from "components/PostPreview.astro";

import { getCollection } from "astro:content";

const allPosts = (
  await getCollection("blog", ({ data }) => !data.isDraft)
).sort((left, right) => {
  return right.data.pubDate.valueOf() - left.data.pubDate.valueOf();
});

const allTags = [...new Set(allPosts.flatMap(({ data }) => data.tags))].sort();
---

<Base title="Blog | Yeison Liscano" description="Yeison Liscano Blog">
  <div class="blog-header">
    <h1>Blog Posts</h1>
    <p class="blog-subtitle">
      Thoughts, tutorials, and insights on software engineering
    </p>
  </div>
  <div class="filter-bar" id="filter-bar">
    <button class="filter-btn active" data-tag="all">All</button>
    {
      allTags.map((tag) => (
        <button class="filter-btn" data-tag={tag}>
          {tag[0].toUpperCase() + tag.slice(1)}
        </button>
      ))
    }
  </div>
  <div class="posts-container" id="posts-container">
    {
      allPosts.map(({ data, id }) => (
        <PostPreview
          title={data.title}
          pubDate={data.pubDate}
          description={data.description}
          tags={data.tags}
          slug={id}
          readingTime={data?.readingTime}
          snippet={data.snippet}
          dataTags={data.tags.join(",")}
        />
      ))
    }
  </div>
</Base>

<style>
  .blog-header {
    margin-bottom: 32px;
    margin-top: 0;
    padding-bottom: 20px;
    padding-top: 0;
    border-bottom: 2px solid var(--contrast);
    opacity: 1;
    width: 100%;
    max-width: 1000px;
    margin-left: auto;
    margin-right: auto;
  }

  @media screen and (max-width: 899px) {
    .blog-header {
      margin-top: 0;
    }
  }

  h1 {
    font-size: 2rem;
    color: var(--text-color);
    margin: 0 0 12px 0;
    line-height: 1.2;
    font-weight: 700;
  }

  .blog-subtitle {
    font-size: 0.95rem;
    color: var(--text-color);
    opacity: 1;
    margin: 0;
    line-height: 1.5;
    font-weight: 400;
  }

  .posts-container {
    display: flex;
    flex-direction: column;
    width: 100%;
    max-width: 1000px;
    margin: 0 auto;
    align-items: center;
    gap: 0;
  }

  .posts-container > :first-child {
    margin-top: 0;
  }

  @media screen and (min-width: 720px) {
    .posts-container {
      gap: 0;
    }
  }

  @media screen and (min-width: 900px) {
    .blog-header {
      margin-top: 20px;
      margin-bottom: 48px;
      padding-bottom: 24px;
    }
  }

  @media screen and (min-width: 720px) {
    h1 {
      font-size: 3.5rem;
      font-weight: 700;
    }

    .blog-header {
      margin-bottom: 60px;
      padding-bottom: 32px;
      border-bottom-width: 3px;
    }

    .blog-subtitle {
      font-size: 1.1rem;
    }
  }

  @media screen and (min-width: 900px) {
    h1 {
      font-size: 4rem;
      font-weight: 700;
    }

    .blog-subtitle {
      font-size: 1.25rem;
      font-weight: 400;
    }
  }

  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    width: 100%;
    max-width: 1000px;
    margin: 0 auto 32px;
  }

  .filter-btn {
    font-family: monospace;
    font-size: 0.8rem;
    padding: 6px 14px;
    border: 1px solid var(--neutral);
    border-radius: 20px;
    background: transparent;
    color: var(--text-color);
    cursor: pointer;
    opacity: 0.7;
    transition:
      opacity 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease;
  }

  .filter-btn:hover {
    opacity: 1;
    border-color: var(--contrast);
    color: var(--contrast);
  }

  .filter-btn.active {
    opacity: 1;
    border-color: var(--contrast);
    color: var(--contrast);
    font-weight: 600;
  }

  @media screen and (min-width: 720px) {
    .filter-bar {
      margin-bottom: 40px;
    }
  }

  @media screen and (min-width: 900px) {
    .filter-bar {
      margin-bottom: 48px;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const filterBar = document.getElementById("filter-bar");
    const postsContainer = document.getElementById("posts-container");
    const posts = document.querySelectorAll<HTMLElement>(
      ".preview-container[data-tags]",
    );

    if (!filterBar || !postsContainer) return;

    function filterByTag(tag: string) {
      filterBar!.querySelectorAll(".filter-btn").forEach((b) => {
        b.classList.toggle("active", (b as HTMLElement).dataset.tag === tag);
      });

      posts.forEach((post) => {
        const show =
          tag === "all" || (post.dataset.tags?.split(",") ?? []).includes(tag);
        post.classList.toggle("visible", show);
        post.style.display = show ? "" : "none";
      });

      const url = new URL(window.location.href);
      if (tag === "all") {
        url.searchParams.delete("tag");
      } else {
        url.searchParams.set("tag", tag);
      }
      window.history.replaceState({}, "", url);
    }

    filterBar.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>(
        ".filter-btn",
      );
      if (!btn || !btn.dataset.tag) return;
      filterByTag(btn.dataset.tag);
    });

    postsContainer.addEventListener("click", (e) => {
      const tagBtn = (e.target as HTMLElement).closest<HTMLButtonElement>(
        "[data-filter-tag]",
      );
      if (!tagBtn || !tagBtn.dataset.filterTag) return;
      filterByTag(tagBtn.dataset.filterTag);
    });

    const initialTag = new URLSearchParams(window.location.search).get("tag");
    if (initialTag) {
      filterByTag(initialTag);
    }
  });
</script>

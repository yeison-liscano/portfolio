---
interface IHeading {
  depth: number;
  slug: string;
  text: string;
}

export interface Props {
  headings: IHeading[];
}

const { headings } = Astro.props;
---

<aside id="toc-aside">
  <div class="toc-header">
    <h4>Table of contents</h4>
    <button
      id="toc-toggle"
      class="toc-btn"
      aria-label="Toggle table of contents"
      aria-expanded="false"
      aria-controls="article-content"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="chevron"
        aria-hidden="true"
      >
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </button>
  </div>
  <ul id="article-content">
    {
      headings.map((heading) => (
        <li class={`h-${heading.depth}`}>
          <a href={`#${heading.slug}`}>{heading.text}</a>
        </li>
      ))
    }
  </ul>
</aside>

<script>
  const tocList = document.getElementById("article-content");
  const tocLinks = tocList?.querySelectorAll("a") ?? [];
  const isDesktop = () => window.innerWidth >= 1300;

  // Scroll-based active heading tracking
  const headingEls = Array.from(tocLinks)
    .map((link) => {
      const id = link.getAttribute("href")?.slice(1);
      return id ? document.getElementById(id) : null;
    })
    .filter(Boolean) as HTMLElement[];

  function updateActiveHeading() {
    if (!tocList) return;
    let activeId = "";

    for (const heading of headingEls) {
      if (heading.getBoundingClientRect().top <= 120) {
        activeId = heading.id;
      }
    }

    tocList.querySelectorAll("li").forEach((li) => {
      const link = li.querySelector("a");
      const href = link?.getAttribute("href")?.slice(1);
      if (href === activeId) {
        li.classList.add("active");
        if (isDesktop()) {
          li.scrollIntoView({ block: "nearest", behavior: "smooth" });
        }
      } else {
        li.classList.remove("active");
      }
    });
  }

  let ticking = false;
  window.addEventListener("scroll", () => {
    if (!ticking) {
      requestAnimationFrame(() => {
        updateActiveHeading();
        ticking = false;
      });
      ticking = true;
    }
  });

  window.addEventListener("load", updateActiveHeading);

  // Mobile collapsible toggle
  const toggle = document.getElementById("toc-toggle");

  toggle?.addEventListener("click", () => {
    if (isDesktop()) return;
    const isOpen = tocList?.classList.toggle("open");
    toggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
  });

  tocLinks.forEach((link) => {
    link.addEventListener("click", () => {
      if (!isDesktop()) {
        tocList?.classList.remove("open");
        toggle?.setAttribute("aria-expanded", "false");
      }
    });
  });
</script>

<style>
  /* ===== MOBILE / TABLET (default) ===== */
  aside {
    width: 100%;
    margin-bottom: 8px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    overflow: hidden;
  }

  .toc-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    background-color: var(--secondary);
    cursor: pointer;
  }

  h4 {
    margin: 0;
    color: var(--contrast);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .toc-btn {
    background: transparent;
    border: none;
    color: var(--text-color);
    cursor: pointer;
    padding: 2px;
    display: flex;
    align-items: center;
    opacity: 0.6;
    transition: opacity 0.2s ease;
  }

  .toc-btn:hover {
    opacity: 1;
  }

  .chevron {
    transition: transform 0.2s ease;
  }

  .toc-btn[aria-expanded="true"] .chevron {
    transform: rotate(180deg);
  }

  /* List hidden by default on mobile */
  ul {
    list-style-type: none;
    padding: 0;
    margin: 0;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  ul.open {
    max-height: 600px;
    padding: 8px 0;
  }

  li {
    margin-left: 0;
    padding: 8px 16px;
  }

  li.active {
    background-color: var(--contrast);
  }

  li.active a {
    color: var(--primary);
  }

  a {
    text-decoration: none;
    white-space: break-spaces;
    color: var(--text-color);
    font-size: 0.875rem;
    line-height: 1.5;
  }

  a:hover {
    color: var(--contrast);
  }

  li:hover {
    background-color: var(--contrast);
  }

  li:hover a {
    color: var(--primary);
  }

  .h-1 {
    font-size: 0.875rem;
  }
  .h-2 {
    font-size: 0.825rem;
    padding-left: 28px;
  }
  .h-3 {
    font-size: 0.775rem;
    padding-left: 44px;
  }
  .h-4 {
    font-size: 0.725rem;
    padding-left: 60px;
  }
  .h-5 {
    font-size: 0.675rem;
    padding-left: 76px;
  }
  .h-6 {
    font-size: 0.625rem;
    padding-left: 92px;
  }

  /* ===== DESKTOP (≥1300px) ===== */
  @media (min-width: 1300px) {
    aside {
      position: fixed;
      right: 24px;
      top: 100px;
      width: 280px;
      max-height: calc(100vh - 200px);
      overflow-y: auto;
      padding: 20px 0;
      background: transparent;
      border: none;
      border-radius: 0;
      box-shadow: none;
      margin-bottom: 0;
      scrollbar-width: none;
    }

    aside::-webkit-scrollbar {
      display: none;
    }

    .toc-header {
      background: none;
      padding: 0 16px 12px;
      cursor: default;
      margin-bottom: 0;
      border-bottom: 1px solid var(--neutral);
    }

    h4 {
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-color);
      opacity: 0.5;
    }

    .toc-btn {
      display: none;
    }

    /* Always show list on desktop */
    ul {
      max-height: none;
      overflow: visible;
      padding: 8px 0;
      transition: none;
      border-left: 2px solid var(--neutral);
      margin-left: 16px;
    }

    li {
      padding: 6px 16px;
      border-radius: 0;
      margin-left: -2px;
      border-left: 2px solid transparent;
      transition: border-color 0.2s ease;
    }

    li:hover {
      background-color: transparent;
      border-left-color: var(--text-color);
    }

    li:hover a {
      color: var(--text-color);
    }

    li.active {
      background-color: transparent;
      border-left-color: var(--contrast);
    }

    li.active a {
      color: var(--contrast);
      font-weight: 600;
    }

    a {
      font-size: 0.8rem;
      opacity: 0.65;
      transition:
        opacity 0.2s ease,
        color 0.2s ease;
    }

    li:hover a {
      opacity: 1;
    }

    li.active a {
      opacity: 1;
    }
  }
</style>

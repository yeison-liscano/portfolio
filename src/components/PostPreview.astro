---
import { Code } from "astro:components";
import type { BuiltinLanguage } from "shiki";

const { BASE_URL } = import.meta.env;

interface Props {
  title: string;
  description: string;
  tags: string[];
  slug: string;
  readingTime: string;
  pubDate: Date;
  snippet: {
    language: BuiltinLanguage;
    code: string;
  };
}

const { title, pubDate, description, tags, slug, readingTime, snippet } =
  Astro.props;

const date = new Date(pubDate).toDateString();
const postUrl = `${BASE_URL}blog/${slug}/`;
---

<div class="preview-container">
  <div class="description-container">
    <span class="label">Article</span>
    <h2>
      <a href={postUrl}>{title}</a>
    </h2>
    <div class="description-card">
      <p>{description}</p>
    </div>
    <div class="tags-container">
      {
        tags.map((tag) => (
          <span class="tag">{tag[0].toUpperCase() + tag.slice(1)}</span>
        ))
      }
    </div>
    <div class="meta">
      <time datetime={pubDate.toDateString()}>{date}</time>
      <span class="separator">&middot;</span>
      <span>{readingTime}</span>
    </div>
  </div>
  <a href={postUrl} class="container-like-image">
    <span class="code-tag">
      {snippet.language[0].toUpperCase() + snippet.language.slice(1)}
    </span>
    <Code
      code={snippet.code}
      lang={snippet.language}
      theme="tokyo-night"
      wrap={true}
    />
  </a>
</div>

<style>
  /* ===== BASE / MOBILE ===== */
  .preview-container {
    margin-top: 48px;
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    width: 100%;
    background-color: transparent;
  }

  .preview-container:first-child {
    margin-top: 0;
  }

  /* --- Label --- */
  .label {
    display: block;
    color: var(--contrast);
    font-size: 0.8rem;
    font-weight: 600;
    font-family: monospace;
    letter-spacing: 0.04em;
    margin-bottom: 8px;
  }

  /* --- Title --- */
  h2 {
    margin: 0 0 16px;
    font-size: 1.5rem;
    line-height: 1.25;
    font-weight: 700;
  }

  h2 a {
    color: var(--text-color);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  h2 a:hover {
    color: var(--contrast);
  }

  /* --- Description card --- */
  .description-card {
    background-color: var(--secondary);
    border-radius: 6px;
    padding: 20px 24px;
    margin-bottom: 16px;
  }

  .description-card p {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--text-color);
  }

  /* --- Tags --- */
  .tags-container {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 12px;
  }

  .tag {
    font-family: monospace;
    font-size: 0.8rem;
    color: var(--text-color);
    opacity: 0.7;
    transition: color 0.2s ease;
  }

  .tag:hover {
    color: var(--contrast);
    opacity: 1;
  }

  /* --- Meta (date + reading time) --- */
  .meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.8rem;
    color: var(--text-color);
    opacity: 0.5;
  }

  .separator {
    opacity: 0.4;
  }

  /* --- Description container --- */
  .description-container {
    grid-column: 1 / -1;
    z-index: 2;
    position: relative;
    display: flex;
    flex-direction: column;
  }

  /* --- Code panel --- */
  .container-like-image {
    grid-column: 1 / -1;
    position: relative;
    display: flex;
    flex-direction: column;
    background-color: var(--code-background);
    border-radius: 8px;
    padding: 20px;
    min-height: 140px;
    max-height: 220px;
    overflow: hidden;
    z-index: 1;
    text-decoration: none;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
    transition:
      box-shadow 0.2s ease,
      transform 0.2s ease;
  }

  .container-like-image:hover {
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.3);
    transform: translateY(-2px);
  }

  .code-tag {
    display: inline-block;
    background-color: var(--neutral);
    color: var(--text-color);
    padding: 4px 10px;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 500;
    margin-bottom: 12px;
    width: fit-content;
    opacity: 0.8;
  }

  [data-theme="light"] .container-like-image {
    background-color: #1d2433;
  }

  @media (prefers-color-scheme: light) {
    .container-like-image {
      background-color: #1d2433;
    }
  }

  .container-like-image pre {
    margin: 0 !important;
    padding: 0 !important;
    font-size: 0.75rem;
    overflow-x: auto;
    max-height: 160px;
    background-color: transparent !important;
  }

  .container-like-image .astro-code {
    margin: 0 !important;
    padding: 0 !important;
    background-color: transparent !important;
    border-radius: 0 !important;
  }

  .container-like-image .astro-code pre {
    margin: 0 !important;
    padding: 0 !important;
  }

  .container-like-image .astro-code code {
    padding: 0 !important;
  }

  .container-like-image .astro-code,
  .container-like-image .astro-code pre,
  .container-like-image .astro-code code,
  .container-like-image .astro-code .line {
    white-space: pre !important;
    word-break: normal !important;
    overflow-wrap: normal !important;
    tab-size: 2;
  }

  /* ===== TABLET (≥720px) ===== */
  @media (min-width: 720px) {
    .preview-container {
      margin-top: 64px;
    }

    h2 {
      font-size: 1.75rem;
    }

    .description-card {
      padding: 24px 28px;
    }
  }

  /* ===== DESKTOP (≥992px) ===== */
  @media (min-width: 992px) {
    .preview-container {
      margin-top: 100px;
      grid-template-columns: repeat(12, 1fr);
      align-items: center;
    }

    h2 {
      font-size: 1.75rem;
      margin-bottom: 20px;
    }

    .description-card {
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
    }

    .container-like-image {
      max-height: 340px;
      min-height: 280px;
      border-radius: 8px;
      padding: 28px;
    }

    /* --- Even cards: description LEFT, code RIGHT --- */
    .preview-container:nth-child(even) .description-container {
      grid-column: 1 / 8;
      grid-row: 1 / 2;
      z-index: 2;
      text-align: left;
    }

    .preview-container:nth-child(even) .description-card {
      margin-right: -60px;
    }

    .preview-container:nth-child(even) .container-like-image {
      grid-column: 7 / 13;
      grid-row: 1 / 2;
      z-index: 1;
    }

    /* --- Odd cards: code LEFT, description RIGHT --- */
    .preview-container:nth-child(odd) .description-container {
      grid-column: 6 / 13;
      grid-row: 1 / 2;
      z-index: 2;
      text-align: right;
    }

    .preview-container:nth-child(odd) .description-card {
      margin-left: -60px;
    }

    .preview-container:nth-child(odd) .tags-container {
      justify-content: flex-end;
    }

    .preview-container:nth-child(odd) .meta {
      justify-content: flex-end;
    }

    .preview-container:nth-child(odd) .container-like-image {
      grid-column: 1 / 8;
      grid-row: 1 / 2;
      z-index: 1;
    }
  }
</style>
